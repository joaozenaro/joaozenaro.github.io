---
import { MousePointer2, Square, MoveUpRight, Grid3X3, Undo2, Redo, Copy } from "lucide-astro";

const { attr, name, label, tooltip, pressed } = Astro.props;

const icons = {
  select: MousePointer2,
  rect: Square,
  arrow: MoveUpRight,
  pixelate: Grid3X3,
  undo: Undo2,
  redo: Redo,
  copy: Copy
} as const;

type Tool = keyof typeof icons;

const ToolIcon = icons[attr as Tool] ?? MousePointer2;
---

<button
    aria-pressed={pressed}
    tabindex="-1"
    data-tool={attr}
    data-tooltip={tooltip || "Not implemented yet"}
    aria-label={label}
>
    <ToolIcon size={15} />
    {name && <span>{name}</span>}
</button>

<style>
    button {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 0 8px;
        height: 28px;
        border: none;
        border-radius: 6px;
        background: transparent;
        color: rgba(255, 255, 255, 0.4);
        font-family: var(--font-sans);
        font-size: 0.8125rem;
        line-height: 1;
        cursor: pointer;
        transition:
            background 100ms ease,
            color 100ms ease;
        white-space: nowrap;
        outline: none;

        &:not(:has(span)) {
            padding: 0;
            width: 28px;
            justify-content: center;
        }

        &:hover:not([aria-disabled="true"]) {
            background: rgba(255, 255, 255, 0.07);
            color: rgba(255, 255, 255, 0.85);
        }

        /* Active / selected tool */
        &[aria-pressed="true"],
        &.active {
            background: rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.9);
        }

        /* Disabled state */
        &[aria-disabled="true"] {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
        }
    }
</style>