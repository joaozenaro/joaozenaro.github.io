---
interface Props {
    title: string
    description: string
    href: string
    image: string
    action: string
}

const { title, description, href, image, action } = Astro.props
---

<a class="project-card" href={href}>
    <img src={image} alt="" loading="lazy" />
    <span class="project-card-body">
        <span class="work-title">{title}</span>
        <span class="work-description">{description}</span>
        <span class="work-action">{action}</span>
    </span>
</a>

<style>
    .project-card {
        display: flex;
        flex-direction: column;
        min-width: 0;
        color: inherit;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 6px;
        overflow: hidden;
        transition:
            background-color 150ms ease,
            border-color 150ms ease;
    }

    .project-card:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: var(--accent);
    }

    .project-card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.04);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .project-card-body {
        display: flex;
        flex: 1;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1.25rem;
    }

    .work-title {
        font-size: 1.15rem;
        line-height: 1.3;
        font-weight: 600;
    }

    .work-description {
        flex: 1;
        font-size: 0.95rem;
        line-height: 1.5;
        color: rgba(219, 219, 219, 0.85);
    }

    .work-action {
        color: var(--accent);
        font-size: 0.9rem;
        text-decoration: underline;
        text-decoration-color: color-mix(
            in srgb,
            var(--accent) 30%,
            transparent
        );
        text-underline-offset: 4px;
        transition:
            color 150ms ease,
            text-decoration-color 150ms ease;
    }

    .project-card:hover .work-action {
        color: var(--fg);
        text-decoration-color: rgb(255 255 255 / 0.8);
    }
</style>
