---
import Layout from '../layouts/Layout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import heatsyncImg from '../assets/heatsync-dash.png'
import agoriumImg from '../assets/agorium.png'
import parkhubImg from '../assets/parkhub.png'

interface WorkItem {
    title: string
    description: string
    href: string
    image: string
    action: string
}

const work: WorkItem[] = [
    {
        title: 'heatsync',
        description:
            'HeatSync is a full-stack IoT dashboard application designed to monitor humidity and temperature in real time.',
        href: 'https://github.com/joaozenaro/heatsync',
        image: heatsyncImg.src,
        action: 'View on GitHub',
    },
    {
        title: 'agorium',
        description:
            'Agorium is a gamified educational app where students connect, ask questions, and share knowledge. With subject-linked posts and a ranking system, it turns learning into a social and interactive experience.',
        href: 'https://github.com/zjefersound/agorium',
        image: agoriumImg.src,
        action: 'View on GitHub',
    },
    {
        title: 'park-hub',
        description:
            'ParkHub is a parking management application built using an unusual PHP framework assigned through a random draw.',
        href: 'https://github.com/joaozenaro/park-hub',
        image: parkhubImg.src,
        action: 'View on GitHub',
    },
]
---

<Layout title="João Zenaro" description="Software developer.">
    <div class="home">
        <section class="landing">
            <p class="eyebrow">Welcome, I'm</p>
            <h1>João M. Zenaro</h1>

            <p class="description">
                I'm a software developer based in Brazil, specializing in .NET
                and web technologies. You can read my <a href="/blog">blog</a>,
                check out my <a href="/tools">tools</a>, or see my <a
                    href="/resume">resume</a
                >.
            </p>
        </section>

        <section class="outside-work" aria-labelledby="outside-work-title">
            <div class="section-heading">
                <p class="eyebrow">Outside work</p>
                <h2 id="outside-work-title">Some personal projects</h2>
            </div>

            <div class="work-grid">
                {
                    work.map((item) => (
                        <ProjectCard
                            title={item.title}
                            description={item.description}
                            href={item.href}
                            image={item.image}
                            action={item.action}
                        />
                    ))
                }
            </div>
        </section>
    </div>
</Layout>

<style>
    .home {
        width: 100%;
    }

    .landing {
        min-height: calc(100vh - 100px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
        max-width: 60rem;
        margin: 0 auto;
        padding: 2rem;
    }

    .eyebrow {
        font-size: 0.875rem;
        opacity: 0.5;
    }

    h1 {
        font-size: 5.5rem;
        line-height: 0.95;
        font-weight: 700;
        letter-spacing: 0;
    }

    .description {
        font-size: 1.125rem;
        line-height: 1.6;
        max-width: 45ch;
        opacity: 0.8;
    }

    .description a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(
            in srgb,
            var(--accent) 30%,
            transparent
        );
        text-underline-offset: 4px;
        transition:
            color 150ms ease,
            text-decoration-color 150ms ease;
    }

    .description a:hover {
        color: var(--fg);
        text-decoration-color: rgb(255 255 255 / 0.8);
    }

    .outside-work {
        width: 100%;
        max-width: 60rem;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
    }

    .section-heading {
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    h2 {
        font-size: 2rem;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: 0;
    }

    .work-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
    }

    @media (max-width: 760px) {
        .landing {
            min-height: auto;
            padding-top: 5rem;
            padding-bottom: 5rem;
        }

        h1 {
            font-size: 3.5rem;
        }

        .work-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
