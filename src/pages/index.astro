---
import Layout from "../layouts/Layout.astro";
---

<Layout title="João Zenaro" description="Software developer.">
	<section class="landing">
		<p class="eyebrow">backend / infra / web</p>
		<h1>João M. Zenaro</h1>

		<p class="description">
			I'm a software developer based in Brazil, specializing in .NET and web technologies. You can read my <a href="/blog">blog</a> or check out my <a href="/tools">tools</a>.
		</p>
	</section>
</Layout>

<style>
	.landing {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1rem;
		max-width: 60rem;
		margin: 0 auto;
		padding: 2rem;
	}

	.eyebrow {
		font-size: 0.875rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.5;
	}

	h1 {
		font-size: clamp(3rem, 10vw, 6rem);
		line-height: 0.95;
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.description {
		font-size: 1.125rem;
		line-height: 1.6;
		max-width: 45ch;
		opacity: 0.8;
	}

	.description a {
		color: inherit;
		text-decoration: underline;
		text-decoration-color: rgb(255 255 255 / 0.3);
		text-underline-offset: 4px;
		transition: text-decoration-color 150ms ease;
	}

	.description a:hover {
		text-decoration-color: rgb(255 255 255 / 0.8);
	}
</style>
