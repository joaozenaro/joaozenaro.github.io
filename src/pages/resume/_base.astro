---
export interface Props {
    title?: string;
    lang?: string;
}

const { title = "Resume", lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>
    <body>
        <slot />

        <script is:inline>
            const urlParams = new URLSearchParams(window.location.search);
            const phone = urlParams.get("phone");
            const phoneUrl = urlParams.get("phone_url") || phone;

            if (phone) {
                document.body.innerHTML = document.body.innerHTML
                    .replace(/@@PHONE@@/g, phone)
                    .replace(/@@PHONE_URL@@/g, phoneUrl);
            } else {
                document.querySelectorAll("dd, li, p").forEach((el) => {
                    if (el.innerHTML.includes("@@PHONE@@")) {
                        el.remove();
                    }
                });
            }
        </script>
    </body>
</html>

<style is:global>
    :root {
        --margin-v: 40px;
        --margin-h: 45px;
        --font-size: 12px;
        --line-height: 1.3;
        --paragraph-space: 4px;
        --page-width: 210mm;
        --page-height: 297mm;
    }

    * {
        box-sizing: border-box;
    }

    body {
        background-color: #f3f4f6;
        margin: 0;
        padding: 40px 0;
        font-family: Verdana, Geneva, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    .resume-body {
        background-color: white;
        color: black;
        text-align: left;
        width: var(--page-width);
        height: var(--page-height);
        margin: 0 auto;
        padding: var(--margin-v) var(--margin-h);
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        font-size: var(--font-size);
        line-height: var(--line-height);
        overflow: hidden;
        position: relative;
    }

    .language-switch {
        display: block;
        width: var(--page-width);
        margin: 0 auto 12px;
        color: #374151;
        font-size: 12px;
        text-align: right;
    }

    .resume-body p,
    .resume-body ul,
    .resume-body ol,
    .resume-body dl {
        margin-top: 0;
        margin-bottom: var(--paragraph-space);
    }

    .resume-body li {
        margin-top: 0;
        margin-bottom: 2px;
    }

    .resume-body li p {
        margin-bottom: 0;
    }

    /* Headings */

    .resume-body h1,
    .resume-body h2,
    .resume-body h3 {
        font-weight: bold;
        line-height: var(--line-height);
    }

    .resume-body h1 {
        font-size: 2.2em;
        letter-spacing: 0.05em;
        text-align: center;
        margin-top: 0;
        margin-bottom: 0.4em;
        border-bottom: 1px solid #000;
    }

    .resume-body h2 {
        font-size: 1.25em;
        margin-top: 12px;
        margin-bottom: 6px;
        border-bottom: 1px solid #000;
    }

    .resume-body h3 {
        font-size: 1.1em;
        margin-top: 8px;
        margin-bottom: 4px;
    }

    /* Lists */

    .resume-body ul,
    .resume-body ol {
        padding-left: 1.5em;
    }

    .resume-body li,
    .resume-body p {
        text-align: justify;
        text-justify: inter-word;
        hyphens: none;
        word-break: keep-all;
    }

    /* Definition Lists (Experience/Education Layout) */

    .resume-body dl {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
    }

    .resume-body dl dd {
        margin: 0;
    }

    .resume-body dl dt {
        flex: 1;
    }

    .resume-body dl dd {
        flex: 1;
        text-align: right;
    }

    /* 3-column layouts: middle column (first dd) alignment */
    .resume-body dl:has(dd:nth-of-type(2)) dd:nth-of-type(1) {
        text-align: center;
    }

    /* 3-column layouts (Experiences): first dd is centered */
    .resume-body dl:has(dd:nth-of-type(2)):has(dt strong) dd:nth-of-type(1) {
        text-align: center;
    }

    /* 3-column layouts (Contact/Other): first dd is left-aligned */
    .resume-body
        dl:has(dd:nth-of-type(2)):not(:has(dt strong))
        dd:nth-of-type(1) {
        text-align: left;
    }

    /* Header */

    .resume-body .resume-header {
        text-align: center;
        margin-bottom: 15px;
    }

    .resume-body .resume-header h1 {
        border-bottom: none;
        margin-bottom: 4px;
    }

    .resume-body .resume-header-item {
        display: inline-block;
    }

    .resume-body a {
        color: inherit;
        text-decoration: underline;
    }

    @page {
        size: A4;
        margin: 0;
    }

    @media print {
        .language-switch {
            display: none !important;
        }

        body {
            background-color: white !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .resume-body {
            box-shadow: none;
            margin: 0 !important;
            width: var(--page-width);
            height: var(--page-height);
        }

        ::-webkit-scrollbar {
            display: none;
        }
    }
</style>
