---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("en", {
		month: "long",
		day: "2-digit",
		year: "numeric",
	}).format(date);
---

<Layout title="Blog" description="My personal web blog">
	<section>
		<div class="post-list-container">
			<h1 class="list-title">Archive</h1>
			<ol class="post-list" aria-label="Blog posts">
				{
					posts.map((post) => {
						return (
							<a class="post-card" href={`/blog/${post.id}/`}>
								<li transition:name={`post-card-${post.id}`}>
									<h2 class="post-title">
										{post.data.title}
									</h2>
									<time
										class="post-date"
										datetime={post.data.date.toISOString()}
									>
										{formatDate(post.data.date)}
									</time>
									<p class="post-description">
										{post.data.description}
									</p>
								</li>
							</a>
						);
					})
				}
			</ol>
		</div>
	</section>
</Layout>

<style>
	section {
		flex: 1;
		display: flex;
		justify-content: center;
		padding: 3rem 1.5rem;
	}

	.post-list-container {
		width: 100%;
		max-width: 720px;
		display: flex;
		flex-direction: column;
	}

	.list-title {
		font-size: 2rem;
		font-weight: 700;
		color: var(--fg);
		margin-bottom: 2rem;
		letter-spacing: -0.02em;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		padding-bottom: 0.75rem;
	}

	.post-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 0;
		margin: 0;
	}

	.post-card {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.post-card li {
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 6px;
		transition:
			border-color 150ms ease,
			background-color 150ms ease;
		box-sizing: border-box;
	}

	.post-card:hover li {
		background: rgba(255, 255, 255, 0.04);
		border-color: var(--accent);
	}

	.post-title {
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--fg);
		margin: 0 0 0.4rem 0;
		line-height: 1.3;
		transition: color 150ms ease;
	}

	.post-date {
		font-size: 0.85rem;
		opacity: 0.5;
		display: block;
		margin-bottom: 0.75rem;
		letter-spacing: 0.02em;
	}

	.post-description {
		font-size: 0.95rem;
		line-height: 1.5;
		color: rgba(219, 219, 219, 0.85);
		margin: 0;
	}
</style>
