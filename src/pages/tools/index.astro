---
import Layout from "../../layouts/Layout.astro";

interface Tool {
	id: string;
	name: string;
	description: string;
	href: string;
}

const tools: Tool[] = [
	{
		id: "snip",
		name: "Snip",
		description:
			"Clipboard image annotation tool. Paste an image, annotate it, and copy it back to your clipboard.",
		href: "/tools/snip",
	},
];
---

<Layout title="Tools" description="Useful web tools and utilities">
	<section>
		<div class="tool-list-container">
			<h1 class="list-title">Tools</h1>
			<div class="tool-grid" aria-label="Available tools">
				{
					tools.map((tool) => (
						<a class="tool-card" href={tool.href}>
							<h2 class="tool-name">{tool.name}</h2>
							<p class="tool-description">{tool.description}</p>
						</a>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	section {
		flex: 1;
		display: flex;
		justify-content: center;
		padding: 3rem 1.5rem;
	}

	.tool-list-container {
		width: 100%;
		max-width: 720px;
		display: flex;
		flex-direction: column;
	}

	.list-title {
		font-size: 2rem;
		font-weight: 700;
		color: var(--fg);
		margin-bottom: 2rem;
		letter-spacing: -0.02em;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		padding-bottom: 0.75rem;
	}

	.tool-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
	}

	.tool-card {
		text-decoration: none;
		color: inherit;
		display: block;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 6px;
		transition:
			border-color 150ms ease,
			background-color 150ms ease;
	}

	.tool-card:hover {
		background: rgba(255, 255, 255, 0.04);
		border-color: var(--accent);
	}

	.tool-name {
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--fg);
		margin: 0 0 0.5rem 0;
		line-height: 1.3;
	}

	.tool-description {
		font-size: 0.95rem;
		line-height: 1.5;
		color: rgba(219, 219, 219, 0.85);
		margin: 0;
	}
</style>
