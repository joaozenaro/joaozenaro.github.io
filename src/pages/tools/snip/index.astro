---
import Button from '@components/snip/Button.astro'
import CanvasArea from '@components/snip/CanvasArea.astro'
import EmptyState from '@components/snip/EmptyState.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import ColorPicker from './ColorPicker.astro'
---

<BaseLayout
    title="Snip"
    description="Clipboard image annotation tool. Paste an image, annotate it, and copy it back to your clipboard."
>
    <main>
        <!-- Toolbar -->
        <header>
            <div>Snip</div>

            <div role="toolbar" aria-label="Tools">
                <Button attr="select" name="Select" pressed />
                <Button attr="rect" name="Rect" />
                <Button attr="arrow" name="Arrow" />
                <Button attr="pixelate" name="Pixelate" />
                <ColorPicker />
            </div>

            <div class="right">
                <Button id="btn-undo" attr="undo" label="Undo" />
                <Button id="btn-redo" attr="redo" label="Redo" />
                <Button
                    id="btn-copy"
                    attr="copy"
                    label="Copy"
                    tooltip="Paste an image first"
                />
            </div>
        </header>

        <!-- Canvas area -->
        <section>
            <EmptyState />
            <CanvasArea />
        </section>
    </main>
</BaseLayout>

<script>
    import './init.ts'
</script>

<style>
    main {
        flex: 1;
        display: grid;
        grid-template-rows: 48px 1fr;
        font-size: 1.125rem;
    }

    header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 0 1rem;

        .right {
            justify-self: end;
        }
    }

    section {
        flex: 1;
        width: 100%;
        display: grid;
        place-items: center;
    }
</style>
